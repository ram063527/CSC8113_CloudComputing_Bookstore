# 1. Dump inside pod
kubectl exec postgres-0 -- pg_dumpall -U postgres -f /var/lib/postgresql/data/pgdata/pre-demo.dump

# 2. Copy locally
kubectl cp postgres-0:/var/lib/postgresql/data/pgdata/pre-demo.dump ./pre-demo.dump

# 3. Upload to Azure
az storage blob upload `
  --account-name bookstorevelero12 `
  --container-name velero-backups `
  --account-key "$env:VELERO_STORAGE_KEY" `
  --name "dumps/pre-demo-20260316.dump" `
  --file ./pre-demo.dump `
  --overwrite

#4. Confirm
az storage blob list `
  --account-name bookstorevelero12 `
  --container-name velero-backups `
  --account-key "$env:VELERO_STORAGE_KEY" `
  --query "[?contains(name, 'dumps/')].name" `
  --output tsv



